{
  "name": "Heliactyl Next",
  "version": "10.0.0",
  "description": "The official Heliactyl client area for the Pterodactyl Panel.",
  "main": "app.js",
  "author": "Matt James",
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@prisma/client": "^5.22.0",
    "@simplewebauthn/server": "^13.1.1",
    "axios": "^1.13.5",
    "bcrypt": "^5.1.1",
    "chokidar": "^3.6.0",
    "compression": "^1.7.5",
    "connect-pg-simple": "^10.0.0",
    "connect-sqlite3": "^0.9.16",
    "cookie-parser": "^1.4.7",
    "discord.js": "^14.17.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "express-session": "^1.17.2",
    "express-ws": "^4.0.0",
    "form-data": "^4.0.5",
    "ioredis": "^5.4.1",
    "lru-cache": "^7.18.3",
    "nocache": "^4.0.0",
    "node-cache": "^5.1.2",
    "pg": "^8.13.0",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "sqlite3": "^5.1.7",
    "stripe": "^20.2.0",
    "winston": "^3.14.2",
    "ws": "^8.18.0",
    "zod": "^3.24.2"
  },
  "scripts": {
    "mono:build": "cd ../frontend && npm run build",
    "mono:watch": "cd ../frontend && npm run dev",
    "prisma:generate": "node ./scripts/prisma-runner.js generate",
    "prisma:generate:sqlite": "node ./scripts/prisma-runner.js generate --provider=sqlite",
    "prisma:generate:mysql": "node ./scripts/prisma-runner.js generate --provider=mysql",
    "prisma:migrate": "node ./scripts/prisma-runner.js migrate dev",
    "prisma:migrate:sqlite": "node ./scripts/prisma-runner.js migrate dev --provider=sqlite",
    "prisma:migrate:mysql": "node ./scripts/prisma-runner.js migrate dev --provider=mysql",
    "prisma:push": "node ./scripts/prisma-runner.js db push",
    "prisma:push:sqlite": "node ./scripts/prisma-runner.js db push --provider=sqlite",
    "prisma:push:mysql": "node ./scripts/prisma-runner.js db push --provider=mysql",
    "prisma:validate": "node ./scripts/prisma-runner.js validate",
    "prisma:validate:sqlite": "node ./scripts/prisma-runner.js validate --provider=sqlite",
    "prisma:validate:mysql": "node ./scripts/prisma-runner.js validate --provider=mysql",
    "postinstall": "npm run prisma:generate",
    "prestart": "node ./scripts/prisma-runner.js generate",
    "start": "node --no-deprecation app.js"
  },
  "devDependencies": {
    "@babel/cli": "^7.23.9",
    "@babel/core": "^7.24.0",
    "@babel/plugin-transform-modules-commonjs": "^7.23.3",
    "@babel/preset-env": "^7.24.0",
    "prisma": "^5.22.0"
  }
}
